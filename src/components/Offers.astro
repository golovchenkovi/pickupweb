---
const offers = [
  {
    tier: "Quick Fix",
    title: "Text Consultation",
    price: "$25",
    period: "30 min",
    description: "Chat-based guidance with message analysis. Send me the conversation — I'll tell you exactly what to say next.",
    features: [
      "Message & chat analysis",
      "Texting strategy",
      "Situational advice",
      "Response within 1h",
      "Follow-up guidance"
    ],
    cta: "Start Chat",
    ctaLink: "https://t.me/golovchenko_vi",
    highlight: false
  },
  {
    tier: "Deep Dive",
    title: "1-on-1 Call",
    price: "$100",
    period: "per session",
    description: "A live strategy session where we dissect your situation and build a step-by-step action plan.",
    features: [
      "60-min video/voice call",
      "Personalized strategy",
      "Situation breakdown and analysis",
      "Mindset recalibration",
      "Action plan in PDF format"
    ],
    cta: "Book a Call",
    ctaLink: "https://t.me/golovchenko_vi",
    highlight: true
  },
  {
    tier: "Full Access",
    title: "Monthly Guidance",
    price: "$1000",
    period: "per month",
    description: "Your personal wingman on speed dial. Full guidance, skill upgrades, and real-time help whenever you need it.",
    features: [
      "Unlimited messaging",
      "Weekly strategy calls",
      "Real-time date coaching",
      "Skill development plan",
      "Priority response 24/7"
    ],
    cta: "Apply Now",
    ctaLink: "https://t.me/golovchenko_vi",
    highlight: false
  }
];
---

<section id="offers" class="relative pt-16 pb-16 overflow-hidden" aria-labelledby="offers-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-card/20 to-bg"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Invest in Yourself</span>
      <h2 id="offers-heading" class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        CHOOSE YOUR<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">LEVEL UP</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-stretch reveal reveal-delay-2">
      {offers.map((offer) => (
        <div class:list={[
          "group relative flex flex-col p-8 lg:p-10 rounded-2xl border transition-all duration-500 hover:-translate-y-2",
          offer.highlight
            ? "border-accent/40 bg-gradient-to-b from-accent/10 via-bg-card/80 to-bg-card/50 shadow-[0_0_60px_rgba(255,7,123,0.1)]"
            : "border-white/5 bg-bg-card/30 hover:border-accent/20"
        ]}>

          {offer.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-5 py-1.5 bg-accent text-white text-xs font-bold tracking-[0.15em] uppercase rounded-full shadow-[0_0_20px_rgba(255,7,123,0.4)]">
                Most Popular
              </span>
            </div>
          )}

          <div class="mb-8">
            <span class="text-accent/60 text-xs font-bold tracking-[0.2em] uppercase">{offer.tier}</span>
            <h3 class="text-2xl lg:text-3xl font-black mt-2">{offer.title}</h3>
          </div>

          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="text-2xl lg:text-3xl font-black text-white">{offer.price}</span>
              <span class="text-[#ff087b] text-base">/ {offer.period}</span>
            </div>
          </div>

          <p class="text-white/60 text-sm leading-relaxed mb-8">{offer.description}</p>

          <ul class="space-y-3 mb-10 flex-grow">
            {offer.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm text-white/60">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href={offer.ctaLink || "#contact"}
            target={offer.ctaLink ? "_blank" : undefined}
            rel={offer.ctaLink ? "noopener noreferrer" : undefined}
            class:list={[
              "block text-center py-4 rounded-full font-bold text-sm tracking-wide transition-all duration-500",
              offer.highlight
                ? "bg-accent text-white hover:shadow-[0_0_30px_rgba(255,7,123,0.5)] hover:bg-accent-light"
                : "border border-white/20 text-white hover:border-accent hover:text-accent hover:bg-accent/5"
            ]}
          >
            {offer.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>