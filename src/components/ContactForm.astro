---

---

<section id="contact" class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg to-black"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(255,7,123,0.06)_0%,transparent_60%)]"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Let's Talk</span>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        READY TO<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">MAKE A MOVE?</span>
      </h2>
      <p class="text-white/40 mt-6 text-lg max-w-md mx-auto">
        Tell me your situation. No judgment, only solutions.
      </p>
    </div>

    <form class="space-y-6 reveal reveal-delay-2" id="contact-form">
      <div>
        <label for="name" class="block text-sm font-medium text-white/50 mb-2 tracking-wide uppercase">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Your name"
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/20 focus:outline-none focus:border-accent/50 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300"
        />
      </div>

      <div>
        <label for="contact-method" class="block text-sm font-medium text-white/50 mb-2 tracking-wide uppercase">Best way to reach you</label>
        <input
          type="text"
          id="contact-method"
          name="contact"
          required
          placeholder="Telegram / WhatsApp / Instagram"
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/20 focus:outline-none focus:border-accent/50 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-white/50 mb-2 tracking-wide uppercase">Your Situation</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="Tell me what's going on..."
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/20 focus:outline-none focus:border-accent/50 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="group relative w-full py-4 bg-accent text-white font-bold text-lg rounded-xl overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,7,123,0.4)] cursor-pointer"
      >
        <span class="relative z-10">Send Message</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent-light to-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </button>
    </form>

    <p class="text-center text-white/20 text-sm mt-6">
      All consultations are 100% confidential.
    </p>
  </div>
</section>

<!-- Footer -->
<footer class="relative py-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-lg font-bold tracking-tight">
        <span class="text-white">PICKUP</span><span class="text-accent">MASTER</span>
      </div>
      <div class="flex gap-8">
        <a href="#services" class="text-sm text-white/30 hover:text-white/60 transition-colors duration-300">Services</a>
        <a href="#offers" class="text-sm text-white/30 hover:text-white/60 transition-colors duration-300">Offers</a>
        <a href="#contact" class="text-sm text-white/30 hover:text-white/60 transition-colors duration-300">Contact</a>
      </div>
      <p class="text-white/20 text-xs">
        &copy; 2026 Pickupmaster. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    const originalText = btn.querySelector("span")!.textContent;
    btn.querySelector("span")!.textContent = "Message Sent ✓";
    btn.classList.add("bg-green-600");
    btn.classList.remove("bg-accent");
    setTimeout(() => {
      btn.querySelector("span")!.textContent = originalText;
      btn.classList.remove("bg-green-600");
      btn.classList.add("bg-accent");
      form.reset();
    }, 3000);
  });
</script>
