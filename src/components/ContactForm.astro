---

---

<section id="contact" class="relative py-32 overflow-hidden" aria-labelledby="contact-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-bg to-black"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(255,7,123,0.06)_0%,transparent_60%)]"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Let's Talk</span>
      <h2 id="contact-heading" class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        READY TO<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">MAKE A MOVE?</span>
      </h2>
      <p class="text-white/60 mt-6 text-lg max-w-md mx-auto">
        Tell me your situation. No judgment, only solutions.
      </p>
    </div>

    <form class="space-y-6 reveal reveal-delay-2" id="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
      <div>
        <label for="name" class="block text-sm font-medium text-white/70 mb-2 tracking-wide uppercase">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          placeholder="Your name"
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/30 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300"
        />
      </div>

      <div>
        <label for="contact-method" class="block text-sm font-medium text-white/70 mb-2 tracking-wide uppercase">Best way to reach you</label>
        <input
          type="text"
          id="contact-method"
          name="contact"
          required
          placeholder="Telegram / WhatsApp / Instagram"
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/30 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-white/70 mb-2 tracking-wide uppercase">Your Situation</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="Tell me what's going on..."
          class="w-full px-6 py-4 bg-bg-card/50 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/30 focus:shadow-[0_0_20px_rgba(255,7,123,0.1)] transition-all duration-300 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="group relative w-full py-4 bg-accent text-white font-bold text-lg rounded-xl overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,7,123,0.4)] cursor-pointer"
      >
        <span class="relative z-10">Send Message</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent-light to-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </button>
    </form>

    <p class="text-center text-white/50 text-sm mt-6">
      All consultations are 100% confidential.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    const btnText = btn.querySelector("span")!;
    const originalText = btnText.textContent;

    btnText.textContent = "Sending...";
    btn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" }
      });

      if (res.ok) {
        btnText.textContent = "Message Sent \u2713";
        btn.classList.add("bg-green-600");
        btn.classList.remove("bg-accent");
        form.reset();
        setTimeout(() => {
          btnText.textContent = originalText;
          btn.classList.remove("bg-green-600");
          btn.classList.add("bg-accent");
          btn.disabled = false;
        }, 3000);
      } else {
        throw new Error("Failed");
      }
    } catch {
      btnText.textContent = "Error — Try Again";
      btn.classList.add("bg-red-600");
      btn.classList.remove("bg-accent");
      setTimeout(() => {
        btnText.textContent = originalText;
        btn.classList.remove("bg-red-600");
        btn.classList.add("bg-accent");
        btn.disabled = false;
      }, 3000);
    }
  });
</script>
