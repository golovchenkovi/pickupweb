<section class="relative pt-16 pb-16 overflow-hidden" aria-labelledby="testimonials-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-card/20 to-bg"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Proof</span>
      <h2 id="testimonials-heading" class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        THIS IS LIFE <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">IN JAM</span>
      </h2>
    </div>

    <div class="reveal reveal-delay-2 max-w-2xl mx-auto">
      <video
        src="/content/preview_web_video.MOV"
        class="w-full max-h-[80vh] rounded-2xl object-contain bg-black"
        controls
        preload="metadata"
        playsinline
      >
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>
