---
const testimonials = [
  {
    text: "I went from getting ghosted constantly to having three women competing for my attention. The mindset shift alone was worth 10x the investment.",
    name: "Alex K.",
    detail: "28, Software Engineer",
    result: "3 dates in first week"
  },
  {
    text: "He doesn't just tell you what to say — he rewires how you think about yourself. I finally understand what confidence actually means.",
    name: "Mark D.",
    detail: "34, Entrepreneur",
    result: "Now in a relationship"
  },
  {
    text: "Saved my marriage. I was ready to give up, but one session changed everything. The strategies are surgical — precise, effective, immediate.",
    name: "James R.",
    detail: "41, Finance",
    result: "Marriage restored"
  }
];
---

<section class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-card/20 to-bg"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Proof</span>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        REAL MEN.<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">REAL RESULTS.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 reveal reveal-delay-2">
      {testimonials.map((t) => (
        <div class="group p-8 rounded-2xl border border-white/5 bg-bg-card/30 hover:border-accent/20 transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="flex gap-1 mb-6">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-accent">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <blockquote class="text-white/60 leading-relaxed mb-8 flex-grow text-sm">
            "{t.text}"
          </blockquote>

          <div class="flex items-center justify-between border-t border-white/5 pt-6">
            <div>
              <div class="font-bold text-sm">{t.name}</div>
              <div class="text-white/30 text-xs mt-0.5">{t.detail}</div>
            </div>
            <span class="text-accent text-xs font-semibold px-3 py-1 bg-accent/10 rounded-full">{t.result}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
