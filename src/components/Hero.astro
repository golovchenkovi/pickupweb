---

---

<section class="hero">
  <!-- Background -->
  <div class="hero-bg"></div>

  <!-- "WE" — behind photos (z-1) -->
  <h1 class="hero-we">WE</h1>

  <!-- Photos (z-2, z-3) -->
  <img
    src="/content/ag_1.png"
    alt=""
    class="hero-img-ag"
    loading="eager"
  />
  <img
    src="/content/vg_1_fade_1.png"
    alt=""
    class="hero-img-vg"
    loading="eager"
  />

  <!-- "MAKE HER / WANT YOU" — in front of photos (z-4) -->
  <div class="hero-headline">
    <span class="hero-make">MAKE HER</span>
    <span class="hero-want">WANT YOU</span>
  </div>

  <!-- Description (z-5) -->
  <p class="hero-desc">
    We master the art of attraction and connection.<br />
    We build deep, powerful emotional bonds that last.<br />
    We teach you how to create love and live a bold, extraordinary life.
  </p>

  <!-- CTA button -->
  <a href="#services" class="hero-cta">Let's Go</a>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #000 0%, #0a0a0a 50%, #000 100%);
    z-index: 0;
  }

  /* "WE" — giant text behind photos */
  .hero-we {
    position: relative;
    z-index: 1;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(8rem, 20vw, 22rem);
    line-height: 0.85;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0;
    padding-left: 8%;
    padding-top: 6vh;
    user-select: none;
  }

  /* ag_1 — center-right, behind vg */
  .hero-img-ag {
    position: absolute;
    z-index: 2;
    left: 50%;
    transform: translateX(calc(-50% + 25px));
    top: 24%;
    width: 53%;
    max-width: 765px;
    height: auto;
    object-fit: contain;
    pointer-events: none;
  }

  /* vg_1_fade — far right, tall, anchored to top */
  .hero-img-vg {
    position: absolute;
    z-index: 3;
    right: 0;
    top: calc(-1% + 50px);
    height: 105%;
    width: auto;
    max-width: 42%;
    object-fit: cover;
    object-position: top right;
    pointer-events: none;
  }

  /* "MAKE HER" + "WANT YOU" — in front of photos */
  .hero-headline {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    padding-left: 8%;
    margin-top: -0.5vw;
    gap: 0;
  }

  .hero-make,
  .hero-want {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 8.5vw, 10rem);
    line-height: 1;
    letter-spacing: -0.02em;
    display: block;
  }

  .hero-make {
    color: #ffffff;
  }

  .hero-want {
    color: #ff087b;
  }

  /* Description text */
  .hero-desc {
    position: relative;
    z-index: 5;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 300;
    font-size: clamp(0.66rem, 0.9vw, 0.87rem);
    line-height: 1.3;
    color: #ffffff;
    padding-left: 8%;
    margin-top: 1vw;
    max-width: 30%;
  }

  .hero-cta {
    position: relative;
    z-index: 5;
    display: inline-block;
    width: fit-content;
    margin-left: 8%;
    margin-top: 2vw;
    padding: 0.75rem 5rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: #ffffff;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.4s ease;
  }

  .hero-cta:hover {
    border-color: #ff087b;
    color: #ffffff;
    background: #ff087b;
    box-shadow: 0 0 30px rgba(255, 8, 123, 0.5), 0 0 60px rgba(255, 8, 123, 0.25);
    transform: translateY(-2px);
  }

  /* ---------------------------------- */
  /* Responsive                         */
  /* ---------------------------------- */

  @media (max-width: 1024px) {
    .hero-we {
      font-size: clamp(6rem, 18vw, 14rem);
    }

    .hero-make,
    .hero-want {
      font-size: clamp(2.5rem, 8vw, 7rem);
    }

    .hero-img-vg {
      max-width: 50%;
    }

    .hero-img-ag {
      width: 55%;
      right: 2%;
    }

    .hero-desc {
      max-width: 55%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      justify-content: flex-start;
      padding-top: 15vh;
    }

    .hero-we {
      font-size: clamp(5rem, 25vw, 10rem);
      padding-left: 6%;
      padding-top: 0;
    }

    .hero-headline {
      padding-left: 6%;
    }

    .hero-make,
    .hero-want {
      font-size: clamp(2.2rem, 11vw, 5rem);
    }

    .hero-img-vg {
      max-width: 65%;
      height: 85%;
      top: 5%;
    }

    .hero-img-ag {
      width: 70%;
      right: -5%;
      top: 15%;
      opacity: 0.5;
    }

    .hero-desc {
      padding-left: 6%;
      max-width: 75%;
      font-size: 0.85rem;
      margin-top: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 12vh;
    }

    .hero-we {
      font-size: 22vw;
    }

    .hero-make,
    .hero-want {
      font-size: 12vw;
    }

    .hero-img-vg {
      max-width: 80%;
    }

    .hero-img-ag {
      display: none;
    }

    .hero-desc {
      max-width: 90%;
      font-size: 0.8rem;
    }
  }
</style>
