---

---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-gradient-to-br from-black via-bg to-black"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,7,123,0.08)_0%,transparent_70%)]"></div>
  <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-bg to-transparent"></div>

  <!-- Decorative elements -->
  <div class="absolute top-1/4 -right-32 w-96 h-96 bg-accent/5 rounded-full blur-[128px]"></div>
  <div class="absolute bottom-1/4 -left-32 w-80 h-80 bg-accent/3 rounded-full blur-[100px]"></div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
    <div class="opacity-0 animate-fade-in stagger-1">
      <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-[0.25em] uppercase text-accent border border-accent/30 rounded-full mb-8 backdrop-blur-sm">
        Premium Relationship Consulting
      </span>
    </div>

    <h1 class="opacity-0 animate-fade-in-up stagger-2 text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black leading-[0.9] tracking-tighter mb-8">
      MAKE HER<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-accent-light to-accent">
        WANT YOU
      </span>
    </h1>

    <p class="opacity-0 animate-fade-in-up stagger-3 text-lg sm:text-xl md:text-2xl text-white/70 max-w-2xl mx-auto mb-12 font-light leading-relaxed hero-description">
      Master the art of attraction. Build unshakeable confidence.
      <span class="text-white/80">Turn every interaction into an opportunity.</span>
    </p>

    <div class="opacity-0 animate-fade-in-up stagger-4 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#contact"
        class="group relative px-10 py-4 bg-accent text-white font-bold text-lg rounded-full overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,7,123,0.5)] animate-pulse-glow"
      >
        <span class="relative z-10">Book a Session</span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent-light to-accent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      <a
        href="#services"
        class="px-10 py-4 border border-white/20 text-white font-medium text-lg rounded-full hover:border-white/50 hover:bg-white/5 transition-all duration-300"
      >
        Explore Services
      </a>
    </div>

    <!-- Stats strip -->
    <div class="opacity-0 animate-fade-in-up stagger-5 mt-20 flex flex-wrap justify-center gap-8 sm:gap-16">
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-black text-accent">500+</div>
        <div class="text-xs sm:text-sm text-white/60 mt-1 uppercase tracking-wider">Clients Coached</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-black text-accent">98%</div>
        <div class="text-xs sm:text-sm text-white/60 mt-1 uppercase tracking-wider">Success Rate</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-black text-accent">5+</div>
        <div class="text-xs sm:text-sm text-white/60 mt-1 uppercase tracking-wider">Years Experience</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in stagger-6">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center pt-2">
      <div class="w-1 h-3 bg-accent rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
