---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Meet & Communicate",
    description: "Learn how to approach, open, and hold captivating conversations that make her want more.",
    tag: "Foundation"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
    title: "Magnetic Mindset",
    description: "Build the inner frame that makes women feel safe, excited, and addicted to your energy.",
    tag: "Mindset"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Complex Situations",
    description: "Navigating jealousy, mixed signals, breakups, or love triangles — I've seen it all and solved it all.",
    tag: "Strategy"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: "Make Her Fall",
    description: "Beyond attraction — learn the psychology of deep emotional connection that creates lasting desire.",
    tag: "Advanced"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: "Creative Solutions",
    description: "Unconventional problems require unconventional thinking. Get strategies nobody else would think of.",
    tag: "Creative"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
    title: "Any Situation",
    description: "No matter how unusual or impossible it seems — bring it to me. There's always a move to make.",
    tag: "Unlimited"
  }
];
---

<section id="services" class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(255,7,123,0.05)_0%,transparent_50%)]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">What I Do</span>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        YOUR TRANSFORMATION<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">STARTS HERE</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal reveal-delay-2">
      {services.map((service) => (
        <div class="group relative p-8 rounded-2xl border border-white/5 bg-bg-card/30 hover:bg-bg-card-hover transition-all duration-500 hover:border-accent/20 hover:-translate-y-1 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-accent/0 to-accent/0 group-hover:from-accent/5 group-hover:to-transparent transition-all duration-500"></div>

          <div class="relative z-10">
            <div class="flex items-center justify-between mb-6">
              <div class="text-accent/60 group-hover:text-accent transition-colors duration-300" set:html={service.icon} />
              <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/20 group-hover:text-accent/50 transition-colors duration-300 border border-white/10 px-3 py-1 rounded-full">{service.tag}</span>
            </div>

            <h3 class="text-xl font-bold mb-3 group-hover:text-accent transition-colors duration-300">{service.title}</h3>
            <p class="text-white/40 leading-relaxed text-sm group-hover:text-white/60 transition-colors duration-300">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
