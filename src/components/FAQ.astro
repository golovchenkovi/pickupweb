---
const faqs = [
  {
    question: "What kind of relationship problems do you help with?",
    answer: "Everything — from approaching women and building attraction, to fixing broken relationships, handling jealousy, navigating breakups, and making her fall in love. No situation is too complex."
  },
  {
    question: "How does the text consultation work?",
    answer: "Send me your conversation screenshots or describe your situation via chat. I analyze the dynamics, tell you exactly what to say next, and build a texting strategy tailored to your specific scenario. Response within 24 hours."
  },
  {
    question: "What happens during a 1-on-1 call?",
    answer: "A 60-minute deep dive into your situation. We cover personalized strategy, body language coaching, mindset recalibration, and build a step-by-step action plan. The session is recorded so you can review it anytime."
  },
  {
    question: "What does the monthly guidance subscription include?",
    answer: "Your personal wingman on speed dial. Unlimited messaging, weekly strategy calls, real-time date coaching, a structured skill development plan, and priority 24/7 response for any situation that comes up."
  },
  {
    question: "Is everything confidential?",
    answer: "100% confidential. Every conversation, situation, and detail shared during consultations stays strictly between us. Your privacy is non-negotiable."
  }
];
---

<section id="faq" class="relative py-32 overflow-hidden" aria-labelledby="faq-heading">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg-card/20 to-bg"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <span class="text-accent text-sm font-semibold tracking-[0.2em] uppercase">Got Questions?</span>
      <h2 id="faq-heading" class="text-4xl sm:text-5xl md:text-6xl font-black mt-4 tracking-tight">
        FREQUENTLY<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">ASKED</span>
      </h2>
    </div>

    <div class="space-y-4 reveal reveal-delay-2">
      {faqs.map((faq, i) => (
        <details class="group border border-white/5 rounded-2xl bg-bg-card/30 hover:border-accent/20 transition-all duration-300 overflow-hidden">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none text-left">
            <span class="font-semibold text-white/90 group-hover:text-white transition-colors duration-300">
              {faq.question}
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-accent/50 shrink-0 transition-transform duration-300 group-open:rotate-45"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-white/60 leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
