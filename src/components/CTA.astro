---
const consultants = [
  {
    name: "Vitaliy G.",
    role: "Relationship Consultant",
    avatar: "/content/vitaliy-g.png",
    links: {
      telegram: "https://t.me/golovchenko_vi",
      whatsapp: "https://wa.me/375299020323",
      instagram: "https://instagram.com/golovchenko_vi",
    },
  },
  {
    name: "Andrew G.",
    role: "Relationship Consultant",
    avatar: "/content/andrew-g.png",
    links: {
      telegram: "https://t.me/diegosenpier",
      whatsapp: "https://wa.me/37120530261",
      instagram: "https://instagram.com/andrygryadkin",
    },
  },
];
---

<section class="relative pt-32 pb-16 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-accent/5 to-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,7,123,0.12)_0%,transparent_60%)]"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center reveal">
    <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-black leading-tight tracking-tight mb-8">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-white/80">
        "Love everything that moves,
      </span>
      <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-accent-light to-accent">
        and what doesn't move — push it and love it too"
      </span>
    </h2>

    <p class="text-white text-lg md:text-xl max-w-2xl mx-auto mb-16 font-normal">
      Stop overthinking. Stop waiting. The only thing standing between you and the dating life you want is one decision.
    </p>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {consultants.map((c) => (
        <div class="group relative p-8 rounded-3xl border border-white/[0.07] bg-gradient-to-b from-white/[0.04] to-white/[0.01] backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:border-accent/30 hover:shadow-[0_8px_60px_rgba(255,7,123,0.12)]">
          <div class="absolute inset-0 rounded-3xl bg-[radial-gradient(ellipse_at_top,rgba(255,7,123,0.06)_0%,transparent_70%)] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="relative z-10 flex flex-col items-center">
            <div class="relative mb-6">
              <div class="absolute -inset-1 rounded-full bg-gradient-to-br from-accent/40 to-accent-light/20 blur-md opacity-50 group-hover:opacity-80 transition-opacity duration-500"></div>
              <img
                src={c.avatar}
                alt={c.name}
                class="relative w-28 h-28 rounded-full object-cover border-2 border-white/10 group-hover:border-accent/40 transition-all duration-500"
                loading="lazy"
              />
            </div>

            <h3 class="text-xl font-bold tracking-tight">{c.name}</h3>
            <p class="text-white/50 text-sm mt-1 mb-6">{c.role}</p>

            <div class="flex gap-3">
              <a
                href={c.links.telegram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 bg-[#229ED9]/15 text-[#229ED9] text-xs font-semibold rounded-full border border-[#229ED9]/20 hover:bg-[#229ED9] hover:text-white hover:shadow-[0_0_20px_rgba(34,158,217,0.3)] transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M11.944 0A12 12 0 1 0 24 12.056A12.01 12.01 0 0 0 11.944 0Zm5.654 8.22l-1.736 8.19c-.13.587-.48.728-.97.453l-2.68-1.978-1.293 1.244c-.143.143-.264.264-.54.264l.193-2.727 4.97-4.488c.216-.193-.047-.3-.335-.107l-6.14 3.867-2.647-.826c-.575-.18-.587-.575.12-.852l10.34-3.985c.479-.175.898.107.743.83l-.025.115Z"/>
                </svg>
                TG
              </a>
              <a
                href={c.links.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 bg-[#25D366]/15 text-[#25D366] text-xs font-semibold rounded-full border border-[#25D366]/20 hover:bg-[#25D366] hover:text-white hover:shadow-[0_0_20px_rgba(37,211,102,0.3)] transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                WA
              </a>
              <a
                href={c.links.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 bg-[#E1306C]/15 text-[#E1306C] text-xs font-semibold rounded-full border border-[#E1306C]/20 hover:bg-gradient-to-r hover:from-[#833AB4] hover:via-[#E1306C] hover:to-[#F77737] hover:text-white hover:border-transparent hover:shadow-[0_0_20px_rgba(225,48,108,0.3)] transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
                IG
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
