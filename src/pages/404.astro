---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — InJamWeLOVE" description="The page you're looking for doesn't exist.">
  <main id="main-content" class="min-h-screen flex items-center justify-center relative">
    <div class="absolute inset-0 bg-gradient-to-br from-black via-bg to-black"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,7,123,0.08)_0%,transparent_70%)]"></div>

    <div class="relative z-10 text-center px-6">
      <div class="text-8xl sm:text-9xl font-black text-accent/20 mb-4">404</div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight mb-4">
        PAGE NOT <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">FOUND</span>
      </h1>
      <p class="text-white/60 text-lg max-w-md mx-auto mb-10">
        Looks like this page doesn't exist. Let's get you back on track.
      </p>
      <a
        href="/"
        class="inline-block px-10 py-4 bg-accent text-white font-bold text-lg rounded-full hover:shadow-[0_0_40px_rgba(255,7,123,0.5)] transition-all duration-500"
      >
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>
